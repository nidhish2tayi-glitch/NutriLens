# Copy this file to `.env` in the project root and fill in your own values.
# Never commit your real `.env` file to version control.

# OpenAI API key used for ingredient analysis (https://platform.openai.com/api-keys)
OPENAI_API_KEY=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

# OpenAI model to use for analysis
OPENAI_MODEL=gpt-4o-mini

# Vision-capable model used to read text off label photos when Tesseract
# is not installed (defaults to OPENAI_MODEL if not set)
OPENAI_VISION_MODEL=gpt-4o-mini

# Free hosted OCR fallback (https://ocr.space/ocrapi) used automatically when
# Tesseract isn't installed and no OpenAI key is set, so image scanning works
# with zero setup. The default "helloworld" key is OCR.space's public demo
# key (rate-limited). Get your own free key at https://ocr.space/ocrapi for
# higher limits.
OCRSPACE_API_KEY=helloworld

# Path to the SQLite database file (relative to /backend, or absolute)
DATABASE_PATH=../database/nutrilens.db

# Directory where uploaded images are stored (relative to /backend, or absolute)
UPLOAD_DIR=../uploads

# Maximum upload size in megabytes
MAX_UPLOAD_MB=10

# Comma separated list of allowed CORS origins (use * only for local development)
CORS_ORIGINS=*
